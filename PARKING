    def _refresh_dashboard(self):
        stats  = self.db.floor_stats()
        tocc   = sum(s["occupied"] for s in stats)
        tfree  = sum(s["free"]     for s in stats)
        tc, tv = self.db.today_stats()
        self.stat_cards["total_occ"].config(text=str(tocc))
        self.stat_cards["total_free"].config(text=str(tfree))
        self.stat_cards["today_txn"].config(text=str(int(tc)))
        self.stat_cards["today_rev"].config(text=f"Rs.{tv:,.0f}")
        for i, s in enumerate(stats):
            w   = self.floor_widgets[i]
            pct = s["occupied"] / SLOTS_PER_FLOOR
            w["free"].config(text=f"Free: {s['free']}")
            w["occ"].config(text=f"Occupied: {s['occupied']}")
            w["pct"].config(
                text=f"{pct*100:.1f}% full",
                fg=DANGER if pct > 0.8 else WARNING if pct > 0.5 else SUCCESS)
            w["bar_bg"].update_idletasks()
            bw = int(w["bar_bg"].winfo_width() * pct)
            w["bar"].place(x=0, y=0, relheight=1, width=max(bw, 0))
        occupied = self.db.get_occupied_set()
        for sid, dot in self.slot_dots.items():
            if sid in occupied:
                dot.config(text="*", fg=DANGER)
            else:
                dot.config(text="o", fg=SUCCESS)

