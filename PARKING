"""
Smart Parking Management System
================================
- Tkinter GUI, dark theme
- SQLite backend (parking.db) — no Excel dependency
- JPG report export for Active Sessions, Transaction History, Daily Summary
- 4 floors x 125 slots = 500 total capacity
- Rs.50 / hour, min 30 min, rounded up to next hour
"""

import tkinter as tk
from tkinter import ttk, messagebox, filedialog
from datetime import datetime
import os, math, sqlite3

try:
    from PIL import Image, ImageDraw, ImageFont
    PIL_OK = True
except ImportError:
    PIL_OK = False

# ─────────────────────────── CONFIG ─────────────────────────────────────────
DB_FILE         = "parking.db"
RATE_PER_HOUR   = 50
FLOORS          = 4
SLOTS_PER_FLOOR = 125
FLOOR_NAMES     = ["Floor 1 (Ground)", "Floor 2", "Floor 3", "Floor 4 (Top)"]

# ─────────────────────────── PALETTE ────────────────────────────────────────
BG_DARK    = "#0f1117"
BG_CARD    = "#1a1d27"
BG_CARD2   = "#22263a"
ACCENT     = "#6c63ff"
ACCENT2    = "#00d4aa"
ACCENT3    = "#ff6b6b"
ACCENT4    = "#ffd166"
TEXT_PRI   = "#ffffff"
TEXT_SEC   = "#a0aec0"
TEXT_MUTED = "#4a5568"
BORDER     = "#2d3748"
SUCCESS    = "#48bb78"
DANGER     = "#fc8181"
WARNING    = "#f6ad55"

# ─────────────────────────── DATABASE ───────────────────────────────────────
class ParkingDB:
    def __init__(self):
        self.conn = sqlite3.connect(DB_FILE, check_same_thread=False)
        self.conn.row_factory = sqlite3.Row
        self._init_schema()

    def _init_schema(self):
        self.conn.executescript("""
        CREATE TABLE IF NOT EXISTS active_sessions (
            slot_id      TEXT PRIMARY KEY,
            floor        INTEGER,
            slot_no      INTEGER,
            vehicle_no   TEXT,
            entry_time   TEXT,
            vehicle_type TEXT
        );
        CREATE TABLE IF NOT EXISTS transactions (
            txn_id       TEXT PRIMARY KEY,
            vehicle_no   TEXT,
            floor        INTEGER,
            slot_no      INTEGER,
            entry_time   TEXT,
            exit_time    TEXT,
            duration_hrs REAL,
            amount       REAL,
            payment_mode TEXT
        );
        """)
        self.conn.commit()

    def get_active_sessions(self):
        cur = self.conn.execute("SELECT * FROM active_sessions ORDER BY floor, slot_no")
        return [dict(r) for r in cur.fetchall()]

    def get_occupied_set(self):
        cur = self.conn.execute("SELECT slot_id FROM active_sessions")
        return {r[0] for r in cur.fetchall()}

    def find_vehicle(self, vehicle_no):
        cur = self.conn.execute(
            "SELECT * FROM active_sessions WHERE vehicle_no=?", (vehicle_no.upper(),))
        row = cur.fetchone()
        return dict(row) if row else None

    def find_free_slot(self, floor):
        occupied = self.get_occupied_set()
        for s in range(1, SLOTS_PER_FLOOR + 1):
            if f"F{floor}S{s:03d}" not in occupied:
                return s
        return None

    def park_vehicle(self, floor, slot_no, vehicle_no, vehicle_type):
        sid   = f"F{floor}S{slot_no:03d}"
        entry = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        self.conn.execute("INSERT INTO active_sessions VALUES (?,?,?,?,?,?)",
                          (sid, floor, slot_no, vehicle_no.upper(), entry, vehicle_type))
        self.conn.commit()
        return sid, entry

    def checkout_vehicle(self, vehicle_no, payment_mode="Cash"):
        rec = self.find_vehicle(vehicle_no)
        if not rec:
            return None
        exit_dt    = datetime.now()
        entry_dt   = datetime.strptime(rec["entry_time"], "%Y-%m-%d %H:%M:%S")
        hours_raw  = max((exit_dt - entry_dt).total_seconds() / 3600, 0.5)
        hours_bill = math.ceil(hours_raw)
        amount     = hours_bill * RATE_PER_HOUR
        txn_id     = "TXN" + exit_dt.strftime("%Y%m%d%H%M%S")
        exit_str   = exit_dt.strftime("%Y-%m-%d %H:%M:%S")
        self.conn.execute("DELETE FROM active_sessions WHERE slot_id=?", (rec["slot_id"],))
        self.conn.execute("INSERT INTO transactions VALUES (?,?,?,?,?,?,?,?,?)",
                          (txn_id, vehicle_no.upper(), rec["floor"], rec["slot_no"],
                           rec["entry_time"], exit_str,
                           round(hours_raw, 2), amount, payment_mode))
        self.conn.commit()
        return {**rec, "txn_id": txn_id, "exit_time": exit_str,
                "duration_hrs": round(hours_raw, 2),
                "hours_billed": hours_bill, "amount": amount,
                "payment_mode": payment_mode}

    def floor_stats(self):
        occupied = self.get_occupied_set()
        return [{"floor": f,
                 "occupied": sum(1 for s in occupied if s.startswith(f"F{f}S")),
                 "free": SLOTS_PER_FLOOR - sum(1 for s in occupied if s.startswith(f"F{f}S"))}
                for f in range(1, FLOORS + 1)]

    def get_transactions(self, limit=200):
        cur = self.conn.execute(
            "SELECT * FROM transactions ORDER BY exit_time DESC LIMIT ?", (limit,))
        return [dict(r) for r in cur.fetchall()]

    def today_stats(self):
        today = datetime.now().strftime("%Y-%m-%d")
        cur   = self.conn.execute(
            "SELECT COUNT(*), COALESCE(SUM(amount),0) FROM transactions "
            "WHERE exit_time LIKE ?", (f"{today}%",))
        return cur.fetchone()

    def search_vehicle(self, vehicle_no):
        vehicle_no = vehicle_no.upper()
        rec = self.find_vehicle(vehicle_no)
        if rec:
            return "active", rec
        cur = self.conn.execute(
            "SELECT * FROM transactions WHERE vehicle_no=? "
            "ORDER BY exit_time DESC LIMIT 1", (vehicle_no,))
        row = cur.fetchone()
        return ("history", dict(row)) if row else (None, None)


# ─────────────────────────── JPG REPORT ENGINE ──────────────────────────────
def _hex_rgb(h):
    h = h.lstrip("#")
    return tuple(int(h[i:i+2], 16) for i in (0, 2, 4))

def generate_report_jpg(title, subtitle, columns, rows, filename, extra_info=None):
    if not PIL_OK:
        raise RuntimeError("Pillow not installed. Run: pip install Pillow")

    def load_font(size, bold=False):
        candidates = [
            "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf" if bold
            else "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
            "/usr/share/fonts/truetype/liberation/LiberationSans-Bold.ttf" if bold
            else "/usr/share/fonts/truetype/liberation/LiberationSans-Regular.ttf",
            "C:/Windows/Fonts/arialbd.ttf" if bold else "C:/Windows/Fonts/arial.ttf",
            "/System/Library/Fonts/Helvetica.ttc",
        ]
        for p in candidates:
            if os.path.exists(p):
                try:
                    return ImageFont.truetype(p, size)
                except Exception:
                    pass
        return ImageFont.load_default()

    FT  = load_font(28, bold=True)
    FS  = load_font(16)
    FH  = load_font(14, bold=True)
    FC  = load_font(13)
    FF  = load_font(12)

    PAD    = 30
    ROW_H  = 34
    HDR_H  = 42
    TOP_H  = 130 if extra_info else 100
    FTR_H  = 40
    ncols  = len(columns)

    tmp    = Image.new("RGB", (100, 100))
    td     = ImageDraw.Draw(tmp)

    def tw(draw, text, fnt):
        bb = draw.textbbox((0, 0), str(text), font=fnt)
        return bb[2] - bb[0]

    col_w = []
    for ci, col in enumerate(columns):
        w = tw(td, col, FH) + 24
        for row in rows:
            w = max(w, tw(td, str(row[ci]) if ci < len(row) else "", FC) + 20)
        col_w.append(max(w, 80))

    total_w = sum(col_w) + PAD * 2
    total_h = TOP_H + HDR_H + len(rows) * ROW_H + FTR_H + PAD

    BG_C   = _hex_rgb(BG_DARK)
    CARD_C = _hex_rgb(BG_CARD)
    CARD2C = _hex_rgb(BG_CARD2)
    ACC_C  = _hex_rgb(ACCENT)
    ACC2C  = _hex_rgb(ACCENT2)
    ACC4C  = _hex_rgb(ACCENT4)
    WH     = (255, 255, 255)
    GREY_C = _hex_rgb(TEXT_SEC)
    BRD_C  = _hex_rgb(BORDER)

    img  = Image.new("RGB", (total_w, total_h), BG_C)
    draw = ImageDraw.Draw(img)

    # header band
    draw.rectangle([0, 0, total_w, TOP_H], fill=ACC_C)
    draw.text((PAD, 22), title,    font=FT, fill=WH)
    draw.text((PAD, 62), subtitle, font=FS, fill=(220, 220, 255))
    if extra_info:
        draw.text((PAD, 88), extra_info, font=FS, fill=(200, 240, 255))
    ts = datetime.now().strftime("Generated: %d %b %Y  %I:%M %p")
    draw.text((total_w - PAD - tw(draw, ts, FS), 68), ts, font=FS, fill=(200, 200, 240))

    # column headers
    draw.rectangle([0, TOP_H, total_w, TOP_H + HDR_H], fill=CARD2C)
    x = PAD
    for ci, (col, cw) in enumerate(zip(columns, col_w)):
        cx = x + cw // 2 - tw(draw, col, FH) // 2
        draw.text((cx, TOP_H + (HDR_H - 18) // 2), col, font=FH, fill=ACC2C)
        if ci < ncols - 1:
            draw.line([(x + cw, TOP_H), (x + cw, TOP_H + HDR_H)], fill=BRD_C, width=1)
        x += cw

    # data rows
    for ri, row in enumerate(rows):
        y    = TOP_H + HDR_H + ri * ROW_H
        rbg  = BG_C if ri % 2 == 0 else CARD2C
        draw.rectangle([PAD - 5, y, total_w - PAD + 5, y + ROW_H], fill=rbg)
        x = PAD
        for ci, (val, cw) in enumerate(zip(row, col_w)):
            cell = str(val)
            color = WH
            low   = cell.lower()
            if "rs " in low or "rs." in low:      color = ACC4C
            elif "floor" in low:                   color = ACC_C
            elif low in ("car","bike","suv","truck"): color = ACC2C

            while tw(draw, cell, FC) > cw - 10 and len(cell) > 4:
                cell = cell[:-4] + "..."

            cx = x + cw // 2 - tw(draw, cell, FC) // 2
            draw.text((cx, y + (ROW_H - 16) // 2), cell, font=FC, fill=color)
            if ci < ncols - 1:
                draw.line([(x + cw, y), (x + cw, y + ROW_H)], fill=BRD_C, width=1)
            x += cw
        draw.line([(PAD, y + ROW_H), (total_w - PAD, y + ROW_H)], fill=BRD_C, width=1)

    if not rows:
        msg = "No records found."
        draw.text((total_w // 2 - tw(draw, msg, FH) // 2,
                   TOP_H + HDR_H + 20), msg, font=FH, fill=GREY_C)

    # footer
    fy  = total_h - FTR_H + 10
    ftx = f"Smart Parking Management  |  Capacity: 500 vehicles  |  Rate: Rs.{RATE_PER_HOUR}/hr"
    draw.text((PAD, fy), ftx, font=FF, fill=GREY_C)
    draw.line([(0, total_h - FTR_H), (total_w, total_h - FTR_H)], fill=BRD_C, width=1)

    # border
    draw.rectangle([0, 0, total_w - 1, total_h - 1], outline=ACC_C, width=3)

    img.save(filename, "JPEG", quality=95)
    return filename


# ─────────────────────────── BILL WINDOW ─────────────────────────────────────
class BillWindow(tk.Toplevel):
    def __init__(self, parent, d):
        super().__init__(parent)
        self.title("Parking Receipt")
        self.configure(bg=BG_DARK)
        self.resizable(False, False)
        self.grab_set()
        self._build(d)
        self.update_idletasks()
        x = parent.winfo_rootx() + (parent.winfo_width()  - self.winfo_width())  // 2
        y = parent.winfo_rooty() + (parent.winfo_height() - self.winfo_height()) // 2
        self.geometry(f"+{x}+{y}")

    def _build(self, d):
        hdr = tk.Frame(self, bg=ACCENT, pady=18)
        hdr.pack(fill="x")
        tk.Label(hdr, text="🅿  SMART PARKING", bg=ACCENT, fg="white",
                 font=("Helvetica", 18, "bold")).pack()
        tk.Label(hdr, text="OFFICIAL PARKING RECEIPT", bg=ACCENT, fg="#ddd",
                 font=("Helvetica", 10)).pack()

        body = tk.Frame(self, bg=BG_CARD, padx=34, pady=20)
        body.pack(fill="x", padx=2, pady=2)

        def row(lbl, val, vc=TEXT_PRI):
            f = tk.Frame(body, bg=BG_CARD); f.pack(fill="x", pady=3)
            tk.Label(f, text=lbl, bg=BG_CARD, fg=TEXT_SEC, font=("Helvetica", 10),
                     width=20, anchor="w").pack(side="left")
            tk.Label(f, text=val, bg=BG_CARD, fg=vc,
                     font=("Helvetica", 10, "bold"), anchor="w").pack(side="left")

        def sep():
            tk.Frame(body, bg=BORDER, height=1).pack(fill="x", pady=5)

        sep()
        row("Transaction ID:",  d["txn_id"])
        row("Vehicle Number:",  d["vehicle_no"], ACCENT2)
        row("Vehicle Type:",    d["vehicle_type"])
        row("Floor / Slot:",    f"Floor {d['floor']}  |  Slot {d['slot_no']:03d}")
        sep()
        row("Entry Time:",      d["entry_time"])
        row("Exit Time:",       d["exit_time"])
        row("Duration:",
            f"{d['duration_hrs']:.2f} hrs  (billed {d['hours_billed']} hr{'s' if d['hours_billed']>1 else ''})")
        row("Rate:",            f"Rs. {RATE_PER_HOUR} / hour")
        sep()
        row("Payment Mode:",    d["payment_mode"])

        amt_f = tk.Frame(body, bg=ACCENT, pady=12, padx=20)
        amt_f.pack(fill="x", pady=10)
        tk.Label(amt_f, text="TOTAL AMOUNT PAID", bg=ACCENT, fg="white",
                 font=("Helvetica", 10)).pack()
        tk.Label(amt_f, text=f"Rs. {d['amount']:,.0f}", bg=ACCENT, fg="white",
                 font=("Helvetica", 22, "bold")).pack()

        sep()
        tk.Label(body, text="Thank you for parking with us!  Drive safe.",
                 bg=BG_CARD, fg=TEXT_SEC, font=("Helvetica", 9, "italic")).pack()

        def save_jpg():
            if not PIL_OK:
                messagebox.showerror("Missing Library",
                    "Pillow not installed.\nRun: pip install Pillow"); return
            path = filedialog.asksaveasfilename(
                defaultextension=".jpg",
                filetypes=[("JPEG Image", "*.jpg")],
                initialfile=f"Receipt_{d['vehicle_no']}_{d['txn_id']}.jpg")
            if not path: return
            rows_ = [
                ["Transaction ID",  d["txn_id"]],
                ["Vehicle Number",  d["vehicle_no"]],
                ["Vehicle Type",    d["vehicle_type"]],
                ["Floor / Slot",    f"Floor {d['floor']}  |  Slot {d['slot_no']:03d}"],
                ["Entry Time",      d["entry_time"]],
                ["Exit Time",       d["exit_time"]],
                ["Duration",        f"{d['duration_hrs']:.2f} hrs (billed {d['hours_billed']} hr)"],
                ["Rate",            f"Rs. {RATE_PER_HOUR} / hour"],
                ["Payment Mode",    d["payment_mode"]],
                ["TOTAL AMOUNT",    f"Rs. {d['amount']:,.0f}"],
            ]
            generate_report_jpg("PARKING RECEIPT", f"Vehicle: {d['vehicle_no']}",
                                ["Field", "Value"], rows_, path,
                                extra_info=f"Txn: {d['txn_id']}  |  {d['exit_time']}")
            messagebox.showinfo("Saved", f"Receipt saved:\n{path}")

        btn_row = tk.Frame(self, bg=BG_DARK)
        btn_row.pack(fill="x", padx=2, pady=2)
        tk.Button(btn_row, text="  Save Receipt as JPG  ", bg=ACCENT4, fg=BG_DARK,
                  font=("Helvetica", 10, "bold"), relief="flat", pady=9,
                  command=save_jpg, cursor="hand2").pack(side="left", fill="x", expand=True)
        tk.Button(btn_row, text="  Close  ", bg=ACCENT3, fg="white",
                  font=("Helvetica", 10, "bold"), relief="flat", pady=9,
                  command=self.destroy, cursor="hand2").pack(side="left", fill="x", expand=True)


# ─────────────────────────── MAIN APP ────────────────────────────────────────
class ParkingApp(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("Smart Parking Management System")
        self.configure(bg=BG_DARK)
        self.state("zoomed")
        self.minsize(1100, 700)
        self.db = ParkingDB()
        self._build_ui()
        self._refresh_all()
        self.after(30000, self._auto_refresh)

    # ── SKELETON ─────────────────────────────────────────────────
    def _build_ui(self):
        self._build_sidebar()
        self._build_main()

    def _build_sidebar(self):
        sb = tk.Frame(self, bg=BG_CARD, width=232)
        sb.pack(side="left", fill="y")
        sb.pack_propagate(False)

        logo = tk.Frame(sb, bg=ACCENT, pady=20)
        logo.pack(fill="x")
        tk.Label(logo, text="P", bg=ACCENT, fg="white",
                 font=("Helvetica", 40, "bold")).pack()
        tk.Label(logo, text="SMART PARKING", bg=ACCENT, fg="white",
                 font=("Helvetica", 11, "bold")).pack()
        tk.Label(logo, text="Management System", bg=ACCENT, fg="#ccc",
                 font=("Helvetica", 8)).pack()

        tk.Frame(sb, bg=BORDER, height=1).pack(fill="x", pady=5)

        self.nav_btns = {}
        for label, key in [
            ("  Dashboard",           "dashboard"),
            ("  Vehicle Entry",       "entry"),
            ("  Vehicle Exit",        "exit"),
            ("  Active Sessions",     "sessions"),
            ("  Transaction History", "history"),
            ("  Search Vehicle",      "search"),
            ("  Export Reports JPG",  "export"),
        ]:
            btn = tk.Button(sb, text=label, bg=BG_CARD, fg=TEXT_SEC,
                            font=("Helvetica", 10), relief="flat", anchor="w",
                            padx=20, pady=12, cursor="hand2",
                            command=lambda k=key: self._switch_page(k))
            btn.pack(fill="x")
            self.nav_btns[key] = btn

        tk.Frame(sb, bg=BORDER, height=1).pack(fill="x", pady=5)

        info = tk.Frame(sb, bg=BG_CARD2, padx=15, pady=10)
        info.pack(fill="x", padx=10, pady=5)
        tk.Label(info, text="Parking Rate", bg=BG_CARD2, fg=TEXT_SEC,
                 font=("Helvetica", 9, "bold")).pack(anchor="w")
        tk.Label(info, text=f"Rs. {RATE_PER_HOUR} / Hour", bg=BG_CARD2, fg=ACCENT4,
                 font=("Helvetica", 14, "bold")).pack(anchor="w")
        tk.Label(info, text="Min. 30 min charged", bg=BG_CARD2, fg=TEXT_MUTED,
                 font=("Helvetica", 8)).pack(anchor="w")

        tk.Label(sb, text="v2.0  |  Capacity: 500", bg=BG_CARD,
                 fg=TEXT_MUTED, font=("Helvetica", 8)).pack(side="bottom", pady=8)

    def _build_main(self):
        self.main_frame = tk.Frame(self, bg=BG_DARK)
        self.main_frame.pack(side="left", fill="both", expand=True)

        topbar = tk.Frame(self.main_frame, bg=BG_CARD, pady=12, padx=20)
        topbar.pack(fill="x")
        self.page_title = tk.Label(topbar, text="Dashboard", bg=BG_CARD,
                                   fg=TEXT_PRI, font=("Helvetica", 16, "bold"))
        self.page_title.pack(side="left")
        self.clock_lbl = tk.Label(topbar, text="", bg=BG_CARD, fg=TEXT_SEC,
                                  font=("Helvetica", 10))
        self.clock_lbl.pack(side="right")
        self._tick()

        self.pages = {}
        self.content = tk.Frame(self.main_frame, bg=BG_DARK)
        self.content.pack(fill="both", expand=True)

        self._build_dashboard_page()
        self._build_entry_page()
        self._build_exit_page()
        self._build_sessions_page()
        self._build_history_page()
        self._build_search_page()
        self._build_export_page()

        self._switch_page("dashboard")

    def _tick(self):
        self.clock_lbl.config(
            text=datetime.now().strftime("%d %b %Y   %I:%M:%S %p"))
        self.after(1000, self._tick)

    def _switch_page(self, key):
        for f in self.pages.values():
            f.pack_forget()
        self.pages[key].pack(fill="both", expand=True)
        titles = {
            "dashboard": "Dashboard",
            "entry":     "Vehicle Entry",
            "exit":      "Vehicle Exit & Billing",
            "sessions":  "Active Sessions",
            "history":   "Transaction History",
            "search":    "Search Vehicle",
            "export":    "Export Reports as JPG",
        }
        self.page_title.config(text=titles.get(key, key))
        for k, btn in self.nav_btns.items():
            btn.config(bg=ACCENT if k == key else BG_CARD,
                       fg="white" if k == key else TEXT_SEC)
        if key == "sessions":  self._refresh_sessions()
        if key == "history":   self._refresh_history()
        if key == "dashboard": self._refresh_dashboard()

