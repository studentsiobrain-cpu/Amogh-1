    def _save_jpg(self, title, subtitle, columns, rows, default_name, extra=None):
        if not PIL_OK:
            messagebox.showerror("Missing", "Run: pip install Pillow"); return
        if not rows:
            messagebox.showinfo("No Data", "No records to export."); return
        path = filedialog.asksaveasfilename(
            defaultextension=".jpg",
            filetypes=[("JPEG Image", "*.jpg")],
            initialfile=default_name)
        if not path: return
        saved = generate_report_jpg(title, subtitle, columns, rows, path, extra)
        messagebox.showinfo("Exported", f"Report saved to:\n{saved}")

    def _export_sessions(self):
        now  = datetime.now()
        rows = []
        for d in self.db.get_active_sessions():
            entry = datetime.strptime(d["entry_time"], "%Y-%m-%d %H:%M:%S")
            hrs   = (now - entry).total_seconds() / 3600
            rows.append([d["slot_id"], f"Floor {d['floor']}", f"{d['slot_no']:03d}",
                         d["vehicle_no"], d["vehicle_type"],
                         entry.strftime("%d %b %Y %I:%M %p"), f"{hrs:.1f} hrs"])
        self._save_jpg("Active Sessions Report",
                       f"Vehicles currently parked  --  {len(rows)} vehicles",
                       ["Slot ID","Floor","Slot #","Vehicle","Type","Entry Time","Duration"],
                       rows, "Active_Sessions.jpg",
                       extra=f"Occupied: {len(rows)}  |  Available: {500-len(rows)}")

    def _export_history(self):
        rows = []
        for r in self.db.get_transactions(200):
            rows.append([r["txn_id"], r["vehicle_no"],
                         f"Floor {r['floor']}", f"{r['slot_no']:03d}",
                         r["entry_time"][:16], r["exit_time"][:16],
                         f"{r['duration_hrs']} hrs",
                         f"Rs.{r['amount']:,.0f}", r["payment_mode"]])
        self._save_jpg("Transaction History Report",
                       f"Last {len(rows)} completed transactions",
                       ["Txn ID","Vehicle","Floor","Slot","Entry","Exit",
                        "Duration","Amount","Payment"],
                       rows, "Transaction_History.jpg")

    def _export_floor_summary(self):
        stats = self.db.floor_stats()
        tc, tv = self.db.today_stats()
        rows  = []
        for s in stats:
            pct = s["occupied"] / SLOTS_PER_FLOOR * 100
            rows.append([FLOOR_NAMES[s["floor"] - 1],
                         str(SLOTS_PER_FLOOR),
                         str(s["occupied"]), str(s["free"]),
                         f"{pct:.1f}%"])
        tocc = sum(s["occupied"] for s in stats)
        rows.append(["TOTAL", "500", str(tocc), str(500-tocc),
                     f"{tocc/500*100:.1f}%"])
        self._save_jpg("Floor-wise Summary Report",
                       "Occupancy breakdown by floor",
                       ["Floor","Capacity","Occupied","Free","Utilisation"],
                       rows, "Floor_Summary.jpg",
                       extra=f"Today: {int(tc)} transactions  |  Revenue: Rs.{tv:,.0f}")

    def _export_today(self):
        today = datetime.now().strftime("%Y-%m-%d")
        rows  = []
        total = 0.0
        for r in self.db.get_transactions(500):
            if r["exit_time"].startswith(today):
                rows.append([r["txn_id"], r["vehicle_no"],
                             f"Floor {r['floor']}", f"{r['slot_no']:03d}",
                             r["exit_time"][11:16],
                             f"{r['duration_hrs']} hrs",
                             f"Rs.{r['amount']:,.0f}", r["payment_mode"]])
                total += r["amount"]
        self._save_jpg("Today's Revenue Report",
                       f"Transactions on {datetime.now().strftime('%d %b %Y')}",
                       ["Txn ID","Vehicle","Floor","Slot","Exit Time",
                        "Duration","Amount","Payment"],
                       rows, f"Revenue_{today}.jpg",
                       extra=f"Total Transactions: {len(rows)}  |  Total Revenue: Rs.{total:,.0f}")

    # ── TREE HELPER ───────────────────────────────────────────────
    def _make_tree(self, parent, cols, widths, labels):
        style = ttk.Style()
        style.theme_use("default")
        style.configure("P.Treeview",
                        background=BG_CARD, fieldbackground=BG_CARD,
                        foreground=TEXT_PRI, rowheight=30,
                        font=("Helvetica", 10))
        style.configure("P.Treeview.Heading",
                        background=BG_CARD2, foreground=TEXT_PRI,
                        font=("Helvetica", 10, "bold"), relief="flat")
        style.map("P.Treeview", background=[("selected", ACCENT)])

        frame = tk.Frame(parent, bg=BG_DARK)
        frame.pack(fill="both", expand=True, padx=15, pady=10)
        tree = ttk.Treeview(frame, columns=cols, show="headings", style="P.Treeview")
        for col, w, lbl in zip(cols, widths, labels):
            tree.heading(col, text=lbl)
            tree.column(col, width=w, anchor="center")
        vsb = ttk.Scrollbar(frame, orient="vertical",   command=tree.yview)
        hsb = ttk.Scrollbar(frame, orient="horizontal", command=tree.xview)
        tree.configure(yscrollcommand=vsb.set, xscrollcommand=hsb.set)
        vsb.pack(side="right", fill="y")
        hsb.pack(side="bottom", fill="x")
        tree.pack(fill="both", expand=True)
        return tree

    def _refresh_all(self):
        self._refresh_dashboard()

    def _auto_refresh(self):
        self._refresh_dashboard()
        self.after(30000, self._auto_refresh)


