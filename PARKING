        self.pages["dashboard"] = page

        cards_row = tk.Frame(page, bg=BG_DARK)
        cards_row.pack(fill="x", padx=20, pady=20)
        self.stat_cards = {}
        for key, label, val, color in [
            ("total_occ",  "Total Occupied",  "0",   ACCENT),
            ("total_free", "Total Available", "0",   ACCENT2),
            ("today_txn",  "Today Txns",      "0",   ACCENT4),
            ("today_rev",  "Today Revenue",   "0",   SUCCESS),
        ]:
            card = tk.Frame(cards_row, bg=BG_CARD, padx=20, pady=20)
            card.pack(side="left", fill="both", expand=True, padx=6)
            lbl = tk.Label(card, text=val, bg=BG_CARD, fg=color,
                           font=("Helvetica", 26, "bold"))
            lbl.pack(anchor="w")
            tk.Label(card, text=label, bg=BG_CARD, fg=TEXT_SEC,
                     font=("Helvetica", 9)).pack(anchor="w")
            self.stat_cards[key] = lbl

        tk.Label(page, text="FLOOR-WISE AVAILABILITY", bg=BG_DARK, fg=TEXT_SEC,
                 font=("Helvetica", 10, "bold")).pack(anchor="w", padx=25, pady=(5, 3))

        floors_row = tk.Frame(page, bg=BG_DARK)
        floors_row.pack(fill="x", padx=20)
        self.floor_widgets = []
        colors = [ACCENT, ACCENT2, ACCENT4, "#e056fd"]
        for f in range(FLOORS):
            card = tk.Frame(floors_row, bg=BG_CARD, padx=15, pady=15)
            card.pack(side="left", fill="both", expand=True, padx=6)
            tk.Label(card, text=FLOOR_NAMES[f], bg=BG_CARD, fg=colors[f],
                     font=("Helvetica", 10, "bold")).pack(anchor="w")
            bar_bg = tk.Frame(card, bg=BG_CARD2, height=10)
            bar_bg.pack(fill="x", pady=5)
            bar = tk.Frame(bar_bg, bg=colors[f], height=10, width=0)
            bar.place(x=0, y=0, relheight=1)
            lf = tk.Label(card, text=f"Free: {SLOTS_PER_FLOOR}", bg=BG_CARD,
                          fg=SUCCESS, font=("Helvetica", 12, "bold"))
            lf.pack(anchor="w")
            lo = tk.Label(card, text="Occupied: 0", bg=BG_CARD, fg=DANGER,
