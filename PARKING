    def _fetch_exit(self):
        vno = self.xv_var.get().strip().upper()
        if not vno: return
        rec = self.db.find_vehicle(vno)
        if not rec:
            messagebox.showerror("Not Found", f"{vno} is not currently parked.")
            self.checkout_btn.config(state="disabled"); self._exit_pending = None; return
        entry_dt = datetime.strptime(rec["entry_time"], "%Y-%m-%d %H:%M:%S")
        hrs      = max((datetime.now() - entry_dt).total_seconds() / 3600, 0.5)
        amt      = math.ceil(hrs) * RATE_PER_HOUR
        self.exit_info_lbls["vehicle"].config(
            text=f"{vno}  --  {rec['vehicle_type']}", fg=ACCENT2)
        self.exit_info_lbls["floor_slot"].config(
            text=f"Floor {rec['floor']}  |  Slot {rec['slot_no']:03d}", fg=ACCENT)
        self.exit_info_lbls["entry"].config(
            text=f"Entry: {entry_dt.strftime('%d %b %Y  %I:%M %p')}", fg=TEXT_SEC)
        self.exit_info_lbls["duration"].config(
            text=f"Duration: {hrs:.2f} hrs  (billing {math.ceil(hrs)} hr)", fg=ACCENT4)
        self.exit_info_lbls["amount"].config(
            text=f"Amount Due:  Rs. {amt:,.0f}",
            fg=SUCCESS, font=("Helvetica", 14, "bold"))
        self._exit_pending = vno
        self.checkout_btn.config(state="normal")

    def _checkout(self):
        if not self._exit_pending: return
        result = self.db.checkout_vehicle(self._exit_pending, self.xp_var.get())
        if not result:
            messagebox.showerror("Error", "Checkout failed."); return
        self.xv_var.set("")
        self.checkout_btn.config(state="disabled")
        self._exit_pending = None
        for lbl in self.exit_info_lbls.values():
            lbl.config(text="--", fg=TEXT_PRI, font=("Helvetica", 11))
        self._refresh_dashboard()
        BillWindow(self, result)

