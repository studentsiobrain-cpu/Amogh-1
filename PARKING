    def _refresh_sessions(self):
        for item in self.sess_tree.get_children():
            self.sess_tree.delete(item)
        filt = self.sess_filter.get()
        now  = datetime.now()
        for d in sorted(self.db.get_active_sessions(),
                        key=lambda r: (r["floor"], r["slot_no"])):
            if filt != "All" and d["floor"] != int(filt.split()[1]):
                continue
            entry = datetime.strptime(d["entry_time"], "%Y-%m-%d %H:%M:%S")
            hrs   = (now - entry).total_seconds() / 3600
            dur   = f"{int(hrs)}h {int((hrs % 1)*60)}m"
            self.sess_tree.insert("", "end",
                values=(d["slot_id"], f"Floor {d['floor']}", f"{d['slot_no']:03d}",
                        d["vehicle_no"], entry.strftime("%d %b %Y %I:%M %p"),
                        d["vehicle_type"], dur))

