import tkinter as tk
from tkinter import messagebox, ttk
import requests
from datetime import datetime
import threading

# ==================== CONFIGURATION ====================
# These are constants that don't change
API_KEY = "fd9a00b91af4861dfdf5695fe7c2da50"  # Replace with your actual API key from OpenWeatherMap
BASE_URL = "https://api.openweathermap.org/data/2.5/weather"  # The API endpoint
FORECAST_URL = "https://api.openweathermap.org/data/2.5/forecast"  # For 5-day forecast

# ==================== HELPER FUNCTIONS ====================

def fetch_weather(city):
    """
    Fetches weather data from OpenWeatherMap API
    
    Args:
        city (str): Name of the city to fetch weather for
    
    Returns:
        dict: Dictionary containing weather data or None if error
    """
    try:
        # Build the request parameters
        params = {
            "q": city,              # City name
            "appid": API_KEY,       # Your API key
            "units": "metric"       # Use Celsius (change to "imperial" for Fahrenheit)
        }
        
        # Make the API request
        # The requests library sends an HTTP request to the URL
        response = requests.get(BASE_URL, params=params)
        
        # Check if the request was successful (status code 200 means success)
        if response.status_code == 200:
            # response.json() converts the JSON response into a Python dictionary
            return response.json()
        else:
            # If status is not 200, the city wasn't found or there was an error
            return None
            
    except Exception as e:
        # This catches any other errors (like no internet connection)
        print(f"Error fetching weather: {e}")
        return None


def fetch_forecast(city):
    """
    Fetches 5-day weather forecast
    
    Args:
        city (str): Name of the city
    
    Returns:
        dict: Dictionary containing forecast data or None if error
    """
    try:
        params = {
            "q": city,
            "appid": API_KEY,
            "units": "metric"
        }
        
        response = requests.get(FORECAST_URL, params=params)
        
        if response.status_code == 200:
            return response.json()
        else:
            return None
            
    except Exception as e:
        print(f"Error fetching forecast: {e}")
        return None


def get_weather_icon_emoji(description):
    """
    Converts weather description to an emoji
    
    Args:
        description (str): Weather description from API
    
    Returns:
        str: Emoji representing the weather
    """
    # Create a dictionary mapping weather descriptions to emojis
    emoji_map = {
        "clear": "☀️",
        "cloud": "☁️",
        "rain": "🌧️",
        "thunderstorm": "⛈️",
        "snow": "❄️",
        "mist": "🌫️",
        "drizzle": "🌦️",
        "overcast": "☁️"
    }
    
    # Convert description to lowercase and check if any keyword matches
    description_lower = description.lower()
    for key, emoji in emoji_map.items():
        if key in description_lower:
            return emoji
    
    # If no match found, return a default emoji
    return "🌤️"


# ==================== GUI FUNCTIONS ====================

def on_search_button_click():
    """
    Called when user clicks the search button
    Fetches and displays weather for the entered city
    """
    city = city_entry.get()  # Get the text from the input field
    
    # Check if city name is empty
    if not city.strip():
        messagebox.showwarning("Input Error", "Please enter a city name!")
        return
    
    # Disable the button to prevent multiple simultaneous requests
    search_button.config(state=tk.DISABLED)
    status_label.config(text="Fetching weather data...", fg="#FFD700")
    
    # Run the weather fetching in a separate thread
    # This prevents the GUI from freezing while waiting for API response
    thread = threading.Thread(target=fetch_and_display_weather, args=(city,))
    thread.start()


def fetch_and_display_weather(city):
    """
    Fetches weather data and updates the display
    This runs in a separate thread to avoid freezing the GUI
    
    Args:
        city (str): City name to fetch weather for
    """
    # Fetch current weather
    weather_data = fetch_weather(city)
    
    if weather_data is None:
        # Show error message if API request failed
        messagebox.showerror("Error", f"City '{city}' not found!\nPlease check the spelling and try again.")
        status_label.config(text="Error fetching data", fg="#FF6B6B")
        search_button.config(state=tk.NORMAL)
        return
    
    # Extract data from the response
    # The try-except block handles any unexpected API response format
    try:
        city_name = weather_data["name"]
        country = weather_data["sys"]["country"]
        temp = weather_data["main"]["temp"]
        feels_like = weather_data["main"]["feels_like"]
        humidity = weather_data["main"]["humidity"]
        pressure = weather_data["main"]["pressure"]
        description = weather_data["weather"][0]["description"]
        wind_speed = weather_data["wind"]["speed"]
        
        # Update the display labels with the fetched data
        # We use the config() method to change the text of labels
        
        # City and country
        city_label.config(text=f"{city_name}, {country}")
        
        # Temperature
        temp_label.config(text=f"{temp}°C")
        
        # Weather description with emoji
        weather_emoji = get_weather_icon_emoji(description)
        description_label.config(text=f"{weather_emoji} {description.capitalize()}")
        
        # Feels like temperature
        feels_like_label.config(text=f"Feels Like: {feels_like}°C")
        
        # Additional info
        humidity_label.config(text=f"Humidity: {humidity}%")
        pressure_label.config(text=f"Pressure: {pressure} hPa")
        wind_label.config(text=f"Wind Speed: {wind_speed} m/s")
        
        # Update status
        status_label.config(text=f"Last updated: {datetime.now().strftime('%H:%M:%S')}", fg="#90EE90")
        
        # Fetch and display forecast
        fetch_and_display_forecast(city)
        
    except KeyError as e:
        # Handle cases where expected data is missing from API response
        messagebox.showerror("Error", f"Unexpected response format: {e}")
        status_label.config(text="Error processing data", fg="#FF6B6B")
    
    finally:
        # Re-enable the search button
        search_button.config(state=tk.NORMAL)


def fetch_and_display_forecast(city):
    """
    Fetches and displays 5-day weather forecast
    """
    forecast_data = fetch_forecast(city)
    
    if forecast_data is None:
        return
    
    try:
        # Clear previous forecast data
        for widget in forecast_frame.winfo_children():
            widget.destroy()
        
        # Get forecast items (one every 3 hours, we'll show one per day)
        forecast_list = forecast_data["list"]
        
        # Display next 5 days (one forecast every 24 hours)
        for i in range(0, min(40, len(forecast_list)), 8):  # 8 * 3 hours = 24 hours
            forecast_item = forecast_list[i]
            
            # Extract forecast data
            date_time = forecast_item["dt_txt"]
            date_part = date_time.split()[0]
            temp = forecast_item["main"]["temp"]
            description = forecast_item["weather"][0]["description"]
            weather_emoji = get_weather_icon_emoji(description)
            
            # Create a frame for each day's forecast
            day_frame = tk.Frame(forecast_frame, bg="#2C3E50", relief=tk.RAISED, bd=1)
            day_frame.pack(side=tk.LEFT, padx=5, pady=5)
            
            # Date label
            date_label = tk.Label(day_frame, text=date_part, bg="#2C3E50", 
                                fg="#ECF0F1", font=("Helvetica", 9, "bold"))
            date_label.pack()
            
            # Emoji and temp
            emoji_temp_label = tk.Label(day_frame, text=f"{weather_emoji}\n{temp}°C", 
                                       bg="#2C3E50", fg="#ECF0F1", font=("Helvetica", 10))
            emoji_temp_label.pack()
            
            # Description
            desc_label = tk.Label(day_frame, text=description.capitalize(), 
                                 bg="#2C3E50", fg="#BDC3C7", font=("Helvetica", 8), 
                                 wraplength=70)
            desc_label.pack()
    
    except Exception as e:
        print(f"Error displaying forecast: {e}")


